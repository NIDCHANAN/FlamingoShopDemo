@using FlamingoModel.Models
@model ProductViewDto;


@{
    var groups = Model.TempDetail
        .Where(x => x.StatusUse == 1)
        .GroupBy(x => new { x.CategoryGroupId, x.CategoryGroupName })
        .ToList();
}


<div class="container my-5">
    <div class="app p-4 p-md-5">

        <div class="row g-5 align-items-start">

          <!-- PREVIEW -->
            <div class="col-lg-6">
                <div class="sticky-top" style="top:90px">

                    <h4 class="mb-1">ออกแบบช่อดอกไม้ในฝัน</h4>
                    <small class="text-muted">
                        เลือกดอกไม้ โทนสี และจำนวนตามใจคุณ
                    </small>

                    
                    <!-- Customer Upload Reference -->
                    <div class="upload-ref-box mt-4">

                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <small class="fw-semibold">แนบรูป Ref ของคุณ</small>
                            <small class="text-muted">อัปโหลดได้ 1 รูป</small>
                        </div>

                        <div class="upload-area text-center p-3" onclick="document.getElementById('customerRefInput').click()">

                            <input type="file"
                                    id="customerRefInput"
                                    accept="image/*"
                                    class="d-none"
                                    onchange="previewCustomerRef(event)" />

                            <div id="uploadPlaceholder">
                                <i class="bi bi-image fs-3"></i>
                                <p class="mb-0 small text-muted">คลิกเพื่อเลือกรูป</p>
                            </div>

                            <img id="customerRefPreview"
                                    class="img-fluid rounded d-none mt-2"
                                    style="max-height:150px;" />

                        </div>

                    </div>

                    <!-- Main Preview -->
                    <div class="preview mt-4 position-relative" id="wrapPreview">
                        <img id="aiResult" class="main-preview-img" />

                        <!-- Overlay Loading -->
                        <div class="preview-loading d-none" id="previewLoading">
                            กำลังสร้างภาพ...
                        </div>

                    </div>

                    <!-- TEMPLATE RESULT -->
                <div id="templateResultBox" class="mb-4 d-none">

                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <small class="fw-semibold text-success">
                            แบบที่ตรงกับที่คุณเลือก
                        </small>
                    </div>


                    <div class="template-scroll" id="templateScroll">
                    </div>

                 
                </div>


                    <!-- Reference Gallery -->
                    <div class="reference-box mt-4">
                  

                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <small class="fw-semibold">Ref. ตัวอย่างช่อดอกไม้</small>
                            <small class="text-muted">คลิกเพื่อเลือก</small>
                        </div>
                        <div class="ref-wrapper position-relative">

                            <button type="button" class="ref-btn left" onclick="scrollRef(-1,'refScroll')">
                                ‹
                            </button>

                            <div class="ref-scroll" id="refScroll">
                              @foreach(var refer in Model.Images
                                                .Where(x => x.TypeImage == 2)
                                                .GroupBy(x => x.RelationId)
                                                .Select(g => g.First()))
                                {
                                    var refId = Model.Template.Where(x => x.Id == refer.RelationId).FirstOrDefault();

                                    if (refId != null)
                                    {
                                        <img src="@refer.Path" class="ref-item"
                                             data-id="@refId.Id"
                                             data-name="@refId.Name"
                                             data-img="@refer.Path"
                                             data-price="@refId.Price" />
                                    }
                                  
                                }
                            </div>

                            <button type="button" class="ref-btn right" onclick="scrollRef(1,'refScroll')">
                                ›
                            </button>

                        </div>


                    </div>

                </div>
            </div>


            <!-- OPTIONS -->
            <div class="col-lg-6">

                @{
                    var flowerGroup = Model.Groups.FirstOrDefault(x => x.NameCategory == "ดอกไม้");
                }

                <div class="card-ui">
                     <div class="d-flex gap-2 mb-2">
                         <span class="badge rounded-pill text-bg-light">STEP 1</span>
                         <small>เลือกดอกไม้</small>
                     </div>

                    

                    <div class="builder-grid d-flex justify-content-around" >
                        @foreach (var p in Model.Products
                                    .Where(x => x.CategoryGroupId == flowerGroup.Id))
                        {
                             var img = Model.Images
                                        .FirstOrDefault(x => x.RelationId == p.Id);
                             var price = Model.ProductPrice.FirstOrDefault(x => x.CategoryDetailId == p.Id);

                            <div class="paper-item"
                                 data-id="@p.Id"
                                 data-price="@(price?.Price ?? 0)">

                                <img src="@(img?.Path ?? "/Image/noimage.png")" />

                                <div class="paper-name">
                                    @p.NameCategory
                                </div>

                            </div>
                        }

                    </div>


                </div>

                  <div class="card-ui">
                     <div class="d-flex justify-content-between align-items-center mb-3">
                         <div>
                             <span class="badge rounded-pill text-bg-light">STEP 2</span>
                             <small>จำนวนดอก</small>
                         </div>

                         <div class="input-group input-group-sm" style="width:130px">
                             <input type="number"
                                     class="form-control text-center"
                                     id="stemInput"
                                     min="1"
                                     max="99"
                                     value="12">
                         </div>
                     </div>

                     <input type="range"
                             min="1"
                             max="99"
                             step="1"
                             value="12"
                             class="form-range"
                             id="stemRange">
                 </div>

                @{
                    var paperGroup = Model.Groups
                        .FirstOrDefault(x => x.NameCategory == "กระดาษ");

                }

                <div class="card-ui">
                    <div class="d-flex gap-2 mb-2">
                         <span class="badge rounded-pill text-bg-light">STEP 3</span>
                         <small>เลือกกระดาษ</small>
                     </div>
                 
                        <div class="builder-grid d-flex justify-content-around" >

                            @foreach (var p in Model.Products
                                                        .Where(x => x.CategoryGroupId == paperGroup.Id))
                            {
                                var img = Model.Images
                                .FirstOrDefault(x => x.RelationId == p.Id);
                                var pricePaper = Model.ProductPrice.FirstOrDefault(x => x.CategoryDetailId == p.Id);

                                <div class="paper-item"
                                     data-id="@p.Id"
                                     data-price="@(pricePaper?.Price ?? 0)">


                                    <img src="@(img?.Path ?? "/Image/noimage.png")" />

                                    <div class="paper-name">
                                        @p.NameCategory
                                    </div>

                                </div>
                            }
                        </div>
                 </div>


                @{
                    var otherGroup = Model.Groups.Where( x => x.NameCategory != "ดอกไม้" && x.NameCategory != "กระดาษ" )
                        .ToList();
                    // int options = 2;
                }

                @foreach(var other in otherGroup)
                {
                    var countPro = Model.Products
                                 .Where(x => x.CategoryGroupId == other.Id).Count();

                    if (countPro >= 1)
                    {
                        @* options++; *@

                        <div class="card-ui">
                                <div class="d-flex gap-2 mb-2">
                                     <span class="badge rounded-pill text-bg-light">STEP 3</span>
                                     <small>เลือก @other.NameCategory</small>
                                 </div>
                                @* @{
                                    var id = "options" + options;
                                } *@

                               
                                <div class="builder-grid d-flex justify-content-around" >

                                        @foreach (var p in Model.Products
                                                    .Where(x => x.CategoryGroupId == other.Id))
                                        {
                                             var img = Model.Images
                                                        .FirstOrDefault(x => x.RelationId == p.Id);
                                             var pprice = Model.ProductPrice.FirstOrDefault(x => x.CategoryDetailId == p.Id);

                                            <div class="paper-item"
                                                 data-id="@p.Id"
                                                data-price="@(pprice?.Price ?? 0)">


                                                <img src="@(img?.Path ?? "/Image/noimage.png")" />

                                                <div class="paper-name">
                                                    @p.NameCategory
                                                </div>

                                            </div>
                                        }
                                    </div>

                                
                        </div>
                    }

                }
              
            </div>
        </div>
        <!-- SUMMARY CARD -->
        <div class="card-ui mt-4">
            <div class="d-flex justify-content-between align-items-center mb-2">
                <div>
                    <small class="text-muted">ราคารวม</small>
                    <div class="fs-4 fw-semibold text-danger" id="totalPrice">0 บาท</div>
                </div>
                <i class="bi bi-receipt fs-2 text-muted"></i>
            </div>

            <button class="btn btn-soft w-100 py-2 mt-2" onclick="addToCartCustom()">
                <i class="bi bi-bag-plus me-1"></i> เพิ่มลงตะกร้า
            </button>

            <small class="text-muted d-block text-center mt-2">
                ราคาจะอัปเดตอัตโนมัติเมื่อเปลี่ยนตัวเลือก
            </small>
        </div>

    </div>
</div>

