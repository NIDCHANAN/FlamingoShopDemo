@using FlamingoModel.Models
@model OrderViewDto;


<div class="container py-5">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
        <h3 class="fw-bold mb-0">
            <i class="bi bi-clock-history me-2"></i>ประวัติคำสั่งซื้อ
        </h3>

        @* <select class="form-select w-auto">
            <option>ทั้งหมด</option>
            <option>รอชำระเงิน</option>
            <option>กำลังเตรียมสินค้า</option>
            <option>กำลังจัดส่ง</option>
            <option>จัดส่งสำเร็จ</option>
        </select> *@
    </div>

    <!-- ORDER CARD -->
    @foreach (var order in Model.MasterOrder)
    {
        <div class="order-history-card mb-4" data-order="@order.OrderNo">

            <div class="card shadow-sm border-0 rounded-4 p-4">

                <!-- Top Section -->
                <div class="d-flex justify-content-between flex-wrap gap-3">

                    <div>
                        <div class="fw-bold fs-5">ORDER #@order.OrderNo</div>
                        <small class="text-muted">@order.OrderDate.ToString("dd-MMMM-yyyy")</small>
                    </div>

                    @{
                        var colorbadge = order.Status == 0 ? "bg-danger"
                            : order.Status == 1 ? "bg-primary"
                            : order.Status == 2 || order.Status == 3 ? "bg-secondary"
                            : "bg-success";

                        var textbadge = order.Status == 0 ? "รอชำระเงิน"
                        : order.Status == 1 ? "ยืนยันการชำระเงิน"
                        : order.Status == 2 ? "เตรียมสินค้า"
                        : order.Status == 3 ? "กำลังจัดส่ง"
                        : "สำเร็จ";

                        var progress = order.Status == 0 ? 25
                        : order.Status == 1 ? 50
                        : order.Status == 2 ? 75
                        : order.Status == 3 ? 90
                        : 100;

                        var subMaster = Model.SubMasterOrder
                        .Where(x => x.MasterOrderId == order.Id)
                        .ToList();

                        var hasReview = subMaster.Any(x => x.Reating != null && x.Reating > 0);
                        var reviewData = subMaster.FirstOrDefault(x => x.Reating != null && x.Reating > 0);
                    }

                    <div class="text-end">
                        <span class="badge @colorbadge text-white px-3 py-2 rounded-pill">
                            @textbadge
                        </span>
                        @{
                            var totalAmt = (order.TotalPrice ?? 0) - (order.Discount ?? 0);
                        }
                        <div class="fw-semibold text-pink mt-2">฿ @(totalAmt.ToString("N2") ?? "0.00")</div>
                    </div>

                    @if (order.Status == 0)
                    {
                        <button class="btn btn-danger btn-sm mt-2"
                                data-bs-toggle="modal"
                                data-bs-target="#paymentModal"
                                onclick="setPaymentData('@order.Id','@(totalAmt.ToString("N2") ?? "0.00")')">
                            ชำระเงิน
                        </button>
                    }

                    @if (order.Status == 4)
                    {
                        if (hasReview)
                        {
                            <div class="review-box mt-2 p-3 rounded-4 shadow-sm bg-light">

                                <!-- ดาว -->
                                <div class="mb-2">
                                    @{
                                        int rating = reviewData?.Reating ?? 0;
                                    }

                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        if (i <= rating)
                                        {
                                            <i class="bi bi-star-fill text-warning"></i>
                                        }
                                        else
                                        {
                                            <i class="bi bi-star text-warning"></i>
                                        }
                                    }
                                </div>

                                <!-- ความเห็น -->
                                <div class="text-muted small">
                                    "@reviewData?.ResonDetail"
                                </div>

                                <div class="small text-success mt-1">
                                    ✔ รีวิวแล้ว
                                </div>
                            </div>
                        }
                        else
                        {
                            <button class="btn btn-pink btn-sm"
                                    data-bs-toggle="modal"
                                    data-bs-target="#reviewModal"
                                    onclick="setReviewData('@order.Id')">
                                <i class="bi bi-star-fill me-1"></i>ให้คะแนนสินค้า
                            </button>
                        }
                    }
                </div>

                <!-- Progress -->
                <div class="progress mt-4" style="height:8px;">
                    <div class="progress-bar bg-pink" style="width:@progress%"></div>
                </div>

                <div class="d-flex justify-content-between small mt-2 text-muted">
                    <span>รอการชำระ</span>
                    <span>ชำระเงิน</span>
                    <span>เตรียมสินค้า</span>
                    <span>จัดส่ง</span>
                    <span>สำเร็จ</span>
                </div>

                <!-- Footer -->
                <div class="d-flex justify-content-end gap-2 mt-4">
                    <button class="btn btn-outline-pink btn-sm toggle-detail">
                        <i class="bi bi-eye me-1"></i>ดูรายละเอียด
                    </button>
                </div>

            </div>

            <!-- DETAIL SECTION -->
            @{
                var subOrder = Model.SubMasterOrder.Where(x => x.MasterOrderId == order.Id).ToList();
            }
            <div class="order-detail mt-3 d-none">
                <div class="card border-0 shadow-sm rounded-4 p-4">

                    <div class="row g-4">

                        <div class="col-md-6">
                            <h6 class="fw-semibold mb-3">
                                <i class="bi bi-box-seam me-2"></i>รายการสินค้า
                            </h6>

                            @foreach (var sub in subOrder)
                            {
                                var Name = Model.TemplateFlower.Where(x => x.Id == sub.TemplateId).FirstOrDefault();
                                var NameTemp = Name?.Name;
                                if (Name == null)
                                {
                                    NameTemp = "Customization";

                                }

                                <div class="d-flex justify-content-between mb-2">
                                    <span>@NameTemp</span>
                                    <span>x @sub.Qty</span>
                                </div>
                            }
                            

                            <hr>
                            <div class="d-flex justify-content-between fw-semibold">
                                <span>ราคา</span>
                                <span>฿ @(order.TotalPrice?.ToString("N2") ?? "0.00")</span>
                            </div>
                            <div class="d-flex justify-content-between fw-semibold">
                                <span>ส่วนลด</span>
                                <span>฿ @(order.Discount?.ToString("N2") ?? "0.00")</span>
                            </div>
                            <div class="d-flex justify-content-between fw-semibold">
                                <span>รวมทั้งหมด</span>
                                @{
                                    var total = (order.TotalPrice ?? 0) - (order.Discount ?? 0);
                                }
                                <span>฿ @(total.ToString("N2") ?? "0.00")</span>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <h6 class="fw-semibold mb-3">
                                <i class="bi bi-geo-alt me-2"></i>ที่อยู่จัดส่ง
                            </h6>

                            <div class="bg-light rounded-3 p-3">
                                <div class="fw-semibold">@order.fullNameRecrive</div>
                                <div style="white-space: pre-line;">
                                    @order.AddressDelivary
                                </div>
                                <div class="mt-2">
                                    <i class="bi bi-telephone me-1"></i>@order.TelephoneOrder
                                </div>
                            </div>
                        </div>

                    </div>

                </div>
            </div>

        </div>
    
    }
    
</div>

<div class="modal fade" id="reviewModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content rounded-4 border-0 shadow">

            <div class="modal-header border-0">
                <h5 class="modal-title fw-bold text-pink">
                    ⭐ รีวิวคำสั่งซื้อ
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body px-4">

                <input type="hidden" id="reviewOrderId" />

                <!-- ดาว -->
                <div class="text-center mb-4">
                    <div id="starRating" class="fs-2">
                        <i class="bi bi-star star" data-value="1"></i>
                        <i class="bi bi-star star" data-value="2"></i>
                        <i class="bi bi-star star" data-value="3"></i>
                        <i class="bi bi-star star" data-value="4"></i>
                        <i class="bi bi-star star" data-value="5"></i>
                    </div>
                    <small class="text-muted d-block mt-2">
                        แตะที่ดาวเพื่อให้คะแนน
                    </small>
                </div>

                <!-- ความคิดเห็น -->
                <div class="mb-3">
                    <textarea id="reviewComment"
                              class="form-control rounded-3"
                              rows="4"
                              placeholder="เขียนความประทับใจของคุณ..."></textarea>
                </div>

                <input type="hidden" id="reviewScore" value="0" />

            </div>

            <div class="modal-footer border-0">
                <button class="btn btn-light" data-bs-dismiss="modal">ยกเลิก</button>
                <button class="btn btn-pink px-4" onclick="submitReview()">
                    ส่งรีวิว
                </button>
            </div>

        </div>
    </div>
</div>


<!-- Payment Modal -->
<div class="modal fade" id="paymentModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content rounded-4 shadow">

            <div class="modal-header border-0">
                <h5 class="modal-title fw-bold">ชำระเงิน</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body text-center">

                <p class="text-muted mb-3">
                    กรุณาสแกน QR Code และแนบสลิปเพื่อยืนยันการชำระเงิน
                </p>

                <!-- QR -->
                <img src="~/Image/qr-payment.jpg"
                     class="img-fluid rounded-3 shadow-sm mb-3"
                     style="max-width:220px;">

                <h4 class="fw-bold text-success mb-3">
                    <span id="paymentAmountModal"></span>
                </h4>

                <!-- Upload Slip -->
                <div class="mb-3 text-start">
                    <label class="form-label fw-semibold">แนบสลิปการโอน</label>
                    <input type="file"
                           id="slipImage"
                           class="form-control"
                           accept="image/*"
                           onchange="previewSlip(event)">
                </div>

                <!-- Preview -->
                <div class="mb-3">
                    <img id="slipPreview"
                         class="img-fluid rounded-3 shadow-sm d-none"
                         style="max-height:250px;">
                </div>

                <button class="btn btn-success w-100 rounded-3"
                        onclick="confirmPayment()">
                    ยืนยันการชำระเงิน
                </button>

            </div>

        </div>
    </div>
</div>


<script>
    var UploadSlip =  '@Url.Action("UploadSlip", "Customer")';
    var Review =  '@Url.Action("Review", "Customer")';
</script>
<script src="~/js/history.js" asp-append-version="true"></script>
