<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FlamigoFlowerDemo</title>
    <script type="importmap"></script>
    <link rel="shortcut icon" type="image/x-icon" href="~/Image/logo.jpg" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @if (ViewBag.role == "admin")
    {
        <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    }
    else if (ViewBag.role == "customer")
    {
        <link rel="stylesheet" href="~/css/customer.css" asp-append-version="true" />

    }
    else
    {
        <link rel="stylesheet" href="~/css/login.css" asp-append-version="true" />
    }

    <link href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://maps.googleapis.com/maps/api/js?key=AIzaSyAGbVu2XytXYjF1Ros_90RICuM1D8fxats&libraries=places"></script>


    <style>
        /* ปุ่มวงกลมสีน้ำเงิน */
    #scrollTopBtn {
        display: none; /* ซ่อนไว้ก่อน */
        position: fixed;
        bottom: 40px;
        right: 40px;
        z-index: 2000;
        background-color: #0d9556c4; /* สีน้ำเงิน */
        color: white;
        border: none;
        outline: none;
        width: 50px;
        height: 50px;
        border-radius: 50%;
        font-size: 24px;
        cursor: pointer;
        box-shadow: 0 4px 6px rgba(0,0,0,0.3);
        transition: opacity 0.3s;
    }

        #scrollTopBtn:hover {
            background-color: #white; 
        }
    </style>
</head>

<body>
    @{
        var action = ViewContext.RouteData.Values["action"]?.ToString();
        var controller = ViewContext.RouteData.Values["controller"]?.ToString();
    }
    @if (ViewBag.role == "admin" && controller != "Home")
    {
        <div class="d-flex" id="wrapper">
            <!-- Sidebar -->
            <aside id="sidebar">
                <div class="sidebar-header">
                    <img src="~/Image/logo.jpg" class="logo">
                    <span class="logo-text">Flamingo</span>
                </div>
                <ul class="sidebar-menu">
                    <li class="menu-item @(controller == "Monitor" ? "active" : "")">
                        <a asp-controller="Monitor" asp-action="Index" class="menu-link">
                            <i class="bi bi-tv-fill"></i>
                            <span>คำสั่งซื้อ</span>
                        </a>
                    </li>

                    <li class="menu-item @(controller == "Product" ? "active" : "")">
                        <a asp-controller="Product" asp-action="Index" class="menu-link">
                            <i class="bi bi-flower1"></i>
                            <span>สินค้า</span>
                        </a>
                    </li>

                    <li class="menu-item @(controller == "Discount" ? "active" : "")">
                        <a asp-controller="Discount" asp-action="Index" class="menu-link">
                            <i class="bi  bi-award-fill"></i>
                            <span>โปรโมชั่น</span>
                        </a>
                    </li>

                    <li class="menu-item @(controller == "User" ? "active" : "")">
                        <a asp-controller="User" asp-action="Index" class="menu-link">
                            <i class="bi bi-person-lines-fill"></i>
                            <span>ผู้ใช้งาน</span>
                        </a>
                    </li>

                    @*<li class="menu-item">
                        <i class="bi bi-bar-chart"></i>
                        <span>Analytics</span>
                    </li>
                    <li class="menu-item">
                        <i class="bi bi-star"></i>
                        <span>Review</span>
                    </li> *@
                </ul>
            </aside>

            <!-- Page Content -->
            <div id="page-content">

                <!-- Navbar -->
                <nav class="navbar navbar-light bg-white shadow-sm px-4">
                    <button class="btn btn-link text-pink" id="menu-toggle">
                        <i class="bi bi-list fs-3"></i>
                    </button>

                    <div class="ms-auto d-flex align-items-center gap-4">
                        @* <i class="bi bi-bell position-relative">
                            <span class="badge bg-danger">12</span>
                        </i>
                        <i class="bi bi-chat-left-text position-relative">
                            <span class="badge bg-danger">5</span>
                        </i> *@

                        @if (Context.Session.GetString("UserName") != null)
                        {
                           <div class="dropdown">
                                <div class="d-flex align-items-center gap-2 dropdown-toggle"
                                     role="button"
                                     data-bs-toggle="dropdown"
                                     aria-expanded="false"
                                     style="cursor:pointer;">

                                    <img src="@Context.Session.GetString("UserImg")"
                                         class="rounded-circle border"
                                         width="40"
                                         height="40"
                                         alt="User">

                                    <div class="d-none d-md-block text-start">
                                        <small class="text-muted">Welcome!</small><br>
                                        <strong>@Context.Session.GetString("UserName")</strong>
                                    </div>
                                </div>

                                <ul class="dropdown-menu dropdown-menu-end shadow-lg border-0 rounded-4 p-2">
                                    @* <li>
                                        <a class="dropdown-item py-2" asp-controller="Account" asp-action="Profile">
                                            <i class="bi bi-person me-2 text-primary"></i> My Profile
                                        </a>
                                    </li> *@

                                    @* <li>
                                        <a class="dropdown-item py-2" asp-controller="Account" asp-action="ChangePassword">
                                            <i class="bi bi-key me-2 text-warning"></i> Change Password
                                        </a>
                                    </li>

                                    <li>
                                        <a class="dropdown-item py-2" asp-controller="Account" asp-action="EditContact">
                                            <i class="bi bi-pencil-square me-2 text-success"></i> Edit Email / Tel
                                        </a>
                                    </li> *@

                                    <li><hr class="dropdown-divider"></li>

                                    <li>
                                        <a class="dropdown-item text-danger py-2"
                                           asp-controller="Base"
                                           asp-action="Logout">
                                            <i class="bi bi-box-arrow-right me-2"></i> Logout
                                        </a>
                                    </li>
                                </ul>
                            </div>

                        }
                       
                    </div>
                </nav>

                <!-- Content -->
                <div class="container-fluid p-4">
                    <main role="main" class="pb-3">
                        @RenderBody()
                    </main>
                </div>

                <!-- Contact To Admin -->
                <button id="scrollTopBtn" title="Go to top">
                    <i class="bi bi-arrow-up"></i>
                </button>

            </div>
        </div>
    }
    else if ((controller != "Home" && action != "Index") || (controller != "Home" && action == "Index"))
    {
        <nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm py-3">
    <div class="container">

        <!-- LOGO -->
        <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">
            Flamingo
        </a>

        <!-- MOBILE RIGHT (Cart + Hamburger) -->
        <div class="d-flex align-items-center gap-3 d-lg-none">

            <!-- CART -->
            <div class="dropdown position-relative">
                <i class="bi bi-bag fs-5 action-icon"
                   role="button"
                   data-bs-toggle="dropdown"></i>

                <span 
                      class=" cartCount position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger"
                      style="display:none; font-size: 12px;">
                    0
                </span>

                <div class="dropdown-menu dropdown-menu-end p-3 shadow ">
                    <div class="cartItems"></div>
                    <hr>
                    <div class="d-flex justify-content-between mb-3">
                        <span>Subtotal</span>
                        <strong class="text-danger cartTotal">฿0</strong>
                    </div>
                    <a asp-action="checkOut"
                       asp-controller="Customer"
                       class="btn btn-outline-dark w-100">
                        Checkout
                    </a>
                </div>
            </div>

            <!-- HAMBURGER -->
            <button class="navbar-toggler border-0 shadow-none"
                    type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#mainNav">
                <span class="navbar-toggler-icon"></span>
            </button>
        </div>

        <!-- COLLAPSE AREA -->
        <div class="collapse navbar-collapse" id="mainNav">

            <!-- CENTER MENU -->
            <ul class="navbar-nav mx-auto gap-lg-4 text-center">
                <li class="nav-item @(controller == "Customer" && action == "Index" ? "active" : "")">
                    <a class="nav-link" asp-controller="Customer" asp-action="Index">ร้านค้า</a>
                </li>

                <li class="nav-item @(controller == "Customer" && action == "CustomFlower" ? "active" : "")">
                    <a class="nav-link" asp-controller="Customer" asp-action="CustomFlower">โอกาสพิเศษ</a>
                </li>

                <li class="nav-item @(controller == "Customer" && action == "checkOut" ? "active" : "")">
                    <a class="nav-link" asp-controller="Customer" asp-action="checkOut">ชำระเงิน</a>
                </li>
            </ul>

            <!-- DESKTOP RIGHT -->
            <div class="d-flex align-items-center justify-content-around gap-4 ms-auto">

                <!-- SEARCH -->
                <i class="d-none d-lg-flex bi bi-search action-icon"></i>

                <!-- CART -->
                <div class="d-none d-lg-flex dropdown position-relative">
                    <i class="bi bi-bag fs-5 action-icon"
                       role="button"
                       data-bs-toggle="dropdown"></i>

                    <span
                          class=" cartCount position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger"
                          style="display:none; font-size: 12px;">
                        0
                    </span>

                    <div class="dropdown-menu dropdown-menu-end p-3 shadow ">
                        <div class="cartItems"></div>
                        <hr>
                        <div class="d-flex justify-content-between mb-3">
                            <span>Subtotal</span>
                            <strong class="text-danger cartTotal">฿0</strong>
                        </div>
                        <a asp-action="checkOut"
                           asp-controller="Customer"
                           class="btn btn-outline-dark w-100">
                            Checkout
                        </a>
                    </div>
                </div>

                <!-- USER -->
                @if (Context.Session.GetString("UserName") != null)
                {
                    <div class="dropdown">
                        <div class="d-flex align-items-center  gap-3 dropdown-toggle"
                             role="button"
                             data-bs-toggle="dropdown"
                             style="cursor:pointer;">

                            <img src="@Context.Session.GetString("UserImg")"
                                 class="rounded-circle border"
                                 width="40"
                                 height="40"
                                 alt="User">

                            <div class="text-start">
                                <small class="text-muted">Welcome!</small><br>
                                <strong>@Context.Session.GetString("UserName")</strong>
                            </div>
                        </div>

                        <ul class="dropdown-menu dropdown-menu-end shadow-lg border-0 rounded-4 p-2">
                            <li>
                                <a class="dropdown-item py-2"
                                   asp-controller="Account"
                                   asp-action="Profile">
                                    <i class="bi bi-person me-2 text-primary"></i> บัญชี
                                </a>
                            </li>

                            <li>
                                <a class="dropdown-item py-2"
                                   asp-controller="Customer"
                                   asp-action="History">
                                    <i class="bi bi-key me-2 text-warning"></i> ประวัติการสั่งซื้อ
                                </a>
                            </li>

                            <li><hr class="dropdown-divider"></li>

                            <li>
                                <a class="dropdown-item text-danger py-2"
                                   asp-controller="Base"
                                   asp-action="Logout">
                                    <i class="bi bi-box-arrow-right me-2"></i> Logout
                                </a>
                            </li>
                        </ul>
                    </div>
                }
                else
                {
                    <a asp-action="Index"
                       asp-controller="Home"
                       class="btn btn-outline-dark rounded-pill px-4">
                        Login
                    </a>
                }

            </div>

        </div>
    </div>
</nav>



        <div class="container-fluid p-4">
            <main role="main" class="pb-3">
                @RenderBody()
            </main>
        </div>

        <!-- FOOTER (Luxury Style) -->
        <footer class="footer-luxury pt-5 mt-5">
            <div class="container">

            <div class="row gy-4 align-items-start">

                <!-- BRAND -->
                <div class="col-12 col-md-4">
                <h5 class="brand mb-3">Flamingo shop</h5>
                <p class="text-muted small mb-3">
                    ร้านดอกไม้พรีเมียมที่คัดสรรความงดงาม<br>
                    เพื่อทุกช่วงเวลาที่มีความหมายของคุณ
                </p>

                <div class="d-flex gap-3">
                    <a href="#" class="social-icon">
                    <i class="bi bi-tiktok"></i>
                    </a>
                    <a href="https://web.facebook.com/FlamingFlowerBalloonShop?locale=th_TH" class="social-icon">
                    <i class="bi bi-facebook"></i>
                    </a>
                    <a href="https://lin.ee/en2DKTa" class="social-icon">
                    <i class="bi bi-line"></i>
                    </a>
                </div>
                </div>

                <!-- LINKS -->
                <div class="col-6 col-md-4">
                <h6 class="mb-3">บริการลูกค้า</h6>
                <ul class="list-unstyled footer-links">
                    <li><a href="https://lin.ee/en2DKTa">ติดต่อเรา</a></li>
                    <li><a href="#">การจัดส่งสินค้า</a></li>
                    <li><a href="#">คำถามที่พบบ่อย</a></li>
                </ul>
                </div>

                <!-- CONTACT -->
                <div class="col-6 col-md-4">
                <h6 class="mb-3">ติดต่อร้าน</h6>
                <ul class="list-unstyled small text-muted">
                    <li class="mb-2">
                    <i class="bi bi-geo-alt me-2"></i>ร้อยเอ็ด
                    </li>
                    <li class="mb-2">
                    <i class="bi bi-telephone me-2"></i>02-123-4567
                    </li>
                    <li>
                    <i class="bi bi-envelope me-2"></i>info@flamingoshop.com
                    </li>
                </ul>
                </div>

            </div>

            <!-- DIVIDER -->
            <hr class="lux-divider my-4">

            <!-- COPYRIGHT -->
            <div class="text-center pb-4">
                <small class="text-muted">
                © 2026 Flamingo shop · Crafted with care
                </small>
            </div>

            </div>
        </footer>


        <!-- CART OFFCANVAS (Shopee style) -->
        @* <div class="offcanvas offcanvas-end" tabindex="-1" id="cartCanvas">
            <div class="offcanvas-header border-bottom">
            <h5 class="mb-0">
                <i class="bi bi-bag me-2"></i>ตะกร้าสินค้า
            </h5>
            <button class="btn-close" data-bs-dismiss="offcanvas"></button>
            </div>

            <div class="offcanvas-body p-3">
                <div id="cartItems"></div>
            </div>

            <!-- SUMMARY -->
            <div class="border-top p-3">
            <div class="d-flex justify-content-between mb-2">
                <span class="fw-medium">ยอดรวม</span>
                <span class="fw-bold text-danger" id="cartTotal">0 บาท</span>
            </div>
            <button class="btn btn-soft w-100">ไปชำระเงิน</button>
            </div>
        </div> *@


            <!-- Contact To Admin -->
        <button type="button" data-bs-toggle="tooltip" data-bs-placement="left" data-bs-title="ติดต่อพนักงาน" id="scrollTopBtn" title="ContactToAdmin">
            <i class="bi bi-line text-success"></i>
        </button>
    }
    else
    {
            <div class="container-fluid p-4">
            <main role="main" class="pb-3 d-flex justify-content-center">
                @RenderBody()
            </main>
        </div>
        
    }


   
    <script>
        var deletedImageUrl = '@Url.Action("DeleteImages", "Base")';
    </script>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    @if ((action != "Index" && controller != "Home") || (action == "Index" && controller != "Home") && ViewBag.role != "admin" )
    {
        <script src="~/js/site.js" asp-append-version="true"></script>
    }
    else if(ViewBag.role == "admin" )
    {
        <script src="~/js/admin.js" asp-append-version="true"></script>
        
    
    }
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
